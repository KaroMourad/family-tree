{
  "name": "family-tree",
  "version": "0.1.0",
  "private": true,
  "description": "Armenian family tree — React + Express + Postgres",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm --filter @family-tree/server dev\" \"pnpm --filter @family-tree/client dev\"",
    "build": "pnpm --filter @family-tree/server build && pnpm --filter @family-tree/client build",
    "import-json": "pnpm --filter @family-tree/server import-json",
    "create-superadmin": "pnpm --filter @family-tree/server create-superadmin",
    "prisma:migrate": "pnpm --filter @family-tree/server prisma:migrate",
    "prisma:studio": "pnpm --filter @family-tree/server prisma:studio",
    "clean": "rimraf client/node_modules server/node_modules",
    "reinstall": "pnpm run clean && pnpm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3"
  },
  "packageManager": "pnpm@11.3.0"
}
