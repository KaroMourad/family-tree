# Local Postgres (see docker-compose.yml at repo root).
# The host port matches POSTGRES_PORT in the repo-root .env (defaults to 5432).
DATABASE_URL=postgresql://family_tree:family_tree@localhost:5432/family_tree

# Signing secret for app-issued JWTs. Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string

PORT=4000
CLIENT_ORIGIN=http://localhost:5173
